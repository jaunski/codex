{
  "manifest_version": 3,
  "name": "Nova Project Bridge",
  "version": "0.1.0",
  "description": "Captura prompts de projeto/tarefa no ChatGPT e envia para o Nova Project local.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
